{
    "name": "@xwink/sftp",
    "version": "2.5.0",
    "private": false,
    "description": "远程部署SFTP工具",
    "keywords": [
        "command",
        "remote publish",
        "sftp",
        "ssh"
    ],
    "license": "MIT",
    "author": {
        "name": "XWINK",
        "email": "1041367524@qq.com",
        "url": "https://github.com/x-wink"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/x-wink/wink-sftp.git"
    },
    "bin": {
        "wink-sftp": "dist/index.js"
    },
    "files": [
        "dist/src/*.d.ts",
        "dist/index.js",
        "dist/lib/index.js",
        ".claude/skills"
    ],
    "main": "dist/lib/index.js",
    "types": "dist/src/lib.d.ts",
    "exports": {
        ".": {
            "types": "./dist/src/lib.d.ts",
            "import": "./dist/lib/index.js",
            "require": "./dist/lib/index.js"
        }
    },
    "publishConfig": {
        "access": "public"
    },
    "scripts": {
        "dev": "tsx src/index.ts -c sftp.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "e2e": "tsx dev/e2e/run.ts",
        "typecheck": "tsc --noEmit",
        "build": "tsc -emitDeclarationOnly && ncc build ./src/index.ts -o ./dist && ncc build ./src/lib.ts -o ./dist/lib",
        "changelog": "changelogen --output CHANGELOG.md",
        "release": "pnpm run build && changelogen --release && git push --no-follow-tags",
        "release:tag": "git push --follow-tags",
        "lint": "oxlint --fix",
        "lint:check": "oxlint",
        "format": "oxfmt .",
        "format:check": "oxfmt --check ."
    },
    "dependencies": {
        "commander": "^15.0.0",
        "ignore": "^7.0.5",
        "js-yaml": "^4.2.0",
        "ssh2": "^1.17.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^25.9.3",
        "@types/ssh2": "^1.15.5",
        "@vercel/ncc": "^0.44.0",
        "@vitest/coverage-v8": "4.1.9",
        "changelogen": "^0.6.2",
        "oxfmt": "^0.55.0",
        "oxlint": "^1.70.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.9"
    },
    "engines": {
        "node": ">=18"
    },
    "packageManager": "pnpm@11.6.0"
}
